# Docker profile (.env) - app chạy trong container
# Dùng với: npm run env:docker

# --- General ---
COMPOSE_PROJECT_NAME=movie-ticket-booking
ENVIRONMENT=development

# --- Database ---
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=123456
DB_LOGGING=false

# --- Kafka ---
KAFKA_BROKER=kafka:9092

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Service Ports ---
BOOKING_SERVICE_PORT=5001
SEAT_SERVICE_PORT=5002
MOVIE_SERVICE_PORT=5003
PAYMENT_SERVICE_PORT=5004
AUTH_SERVICE_PORT=5005
GATEWAY_PORT=8080
FRONTEND_PORT=3000

# --- Gateway Routing ---
BOOKING_SERVICE_URL=http://booking-service:5001
MOVIE_SERVICE_URL=http://movie-service:5003
PAYMENT_SERVICE_URL=http://payment-service:5004
AUTH_SERVICE_URL=http://auth-service:5005
SEAT_SERVICE_URL=http://seat-service:5002

# --- JWT Auth ---
JWT_SECRET=movie-booking-jwt-secret-key-2026

# --- Debezium ---
DEBEZIUM_AUTO_REGISTER=true
DEBEZIUM_HOST=debezium:8083
DEBEZIUM_CONNECTOR_NAME=outbox-connector
DEBEZIUM_DB_HOST=host.docker.internal
DEBEZIUM_DB_PORT=3306
DEBEZIUM_DB_USER=root
DEBEZIUM_DB_PASSWORD=123456
DEBEZIUM_DB_SERVER_ID=1
DEBEZIUM_TOPIC_PREFIX=saga
DEBEZIUM_SCHEMA_HISTORY_BOOTSTRAP=kafka:9092
DEBEZIUM_SCHEMA_HISTORY_TOPIC=_schema_history_saga

# --- payOS Payment Gateway ---
PAYOS_URL=https://api-merchant.payos.vn
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key