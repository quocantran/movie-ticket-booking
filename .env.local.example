# Local profile (.env) - app chạy trên máy local, infra chạy Docker
# Dùng với: npm run env:local

# --- General ---
COMPOSE_PROJECT_NAME=movie-ticket-booking
ENVIRONMENT=development

# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=123456
DB_LOGGING=false

# --- Kafka ---
KAFKA_BROKER=localhost:9094

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Service Ports ---
BOOKING_SERVICE_PORT=5001
SEAT_SERVICE_PORT=5002
MOVIE_SERVICE_PORT=5003
PAYMENT_SERVICE_PORT=5004
AUTH_SERVICE_PORT=5005
GATEWAY_PORT=8080
FRONTEND_PORT=3000

# --- Gateway Routing ---
BOOKING_SERVICE_URL=http://localhost:5001
MOVIE_SERVICE_URL=http://localhost:5003
PAYMENT_SERVICE_URL=http://localhost:5004
AUTH_SERVICE_URL=http://localhost:5005
SEAT_SERVICE_URL=http://localhost:5002

# --- JWT Auth ---
JWT_SECRET=movie-booking-jwt-secret-key-2026

# --- Debezium ---
DEBEZIUM_AUTO_REGISTER=true
DEBEZIUM_HOST=localhost:8083
DEBEZIUM_CONNECTOR_NAME=outbox-connector
# MySQL chạy local host, Debezium chạy trong container nên dùng host.docker.internal
DEBEZIUM_DB_HOST=host.docker.internal
DEBEZIUM_DB_PORT=3306
DEBEZIUM_DB_USER=root
DEBEZIUM_DB_PASSWORD=123456
DEBEZIUM_DB_SERVER_ID=1
DEBEZIUM_TOPIC_PREFIX=saga
DEBEZIUM_SCHEMA_HISTORY_BOOTSTRAP=kafka:9092
DEBEZIUM_SCHEMA_HISTORY_TOPIC=_schema_history_saga